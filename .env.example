# ===================================
# Environment Variables — {NOME DO PROJETO}
# ===================================
# Copiar para .env.local e preencher com valores reais.
# NUNCA commitar .env.local — só este .env.example.
#
# Para CI/CD, cadastrar como GitHub Secrets:
#   gh secret set NOME_DA_VARIAVEL

# ── Database ──
DATABASE_URL=
# DATABASE_DIRECT_URL=  # (se usar connection pooling)

# ── Auth ──
# AUTH_SECRET=           # (gerar com: openssl rand -base64 32)
# AUTH_PROVIDER_ID=
# AUTH_PROVIDER_SECRET=

# ── APIs externas ──
# API_KEY=

# ── Deploy ──
# NODE_ENV=production
# PYTHON_ENV=production
