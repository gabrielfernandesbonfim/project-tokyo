# ===================================
  # Environment Variables — {PROJECT NAME}
  # ===================================
  # Copy to .env.local and fill in with real values.
  # NEVER commit .env.local — only this .env.example.
  #
  # For CI/CD, register as GitHub Secrets:
  #   gh secret set VARIABLE_NAME

  # ── Database ──
  DATABASE_URL=
  # DATABASE_DIRECT_URL=  # (if using connection pooling)

  # ── Auth ──
  # AUTH_SECRET=           # (generate with: openssl rand -base64 32)
  # AUTH_PROVIDER_ID=
  # AUTH_PROVIDER_SECRET=

  # ── External APIs ──
  # API_KEY=

  # ── Deploy ──
  # NODE_ENV=production
  # PYTHON_ENV=production
